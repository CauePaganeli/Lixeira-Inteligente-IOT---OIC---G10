    {
        "id": "5378e9fde2f273c8",
        "type": "function",
        "z": "bb087744eb5130e2",
        "name": "Extrai percentual",
        "func": "let distancia = msg.payload.distancia_cm;\n\nlet alturaMaxima = 45; // cm\nlet percentual = ((alturaMaxima - distancia) / alturaMaxima) * 100;\n\nif (percentual < 0) percentual = 0;\nif (percentual > 100) percentual = 100;\n\nmsg.payload = Math.round(percentual);\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
