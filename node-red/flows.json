    {
        "id": "d5e93496d6d7ad36",
        "type": "function",
        "z": "bb087744eb5130e2",
        "name": "Extrai Status",
        "func": "let distancia = msg.payload.distancia_cm;\nlet alturaMaxima = 45;\n\nlet percentual = ((alturaMaxima - distancia) / alturaMaxima) * 100;\n\nif (percentual < 0) percentual = 0;\nif (percentual > 100) percentual = 100;\n\nif (percentual < 45) {\n    msg.payload = \"🟢 VAZIA\";\n}\nelse if (percentual < 75) {\n    msg.payload = \"🟡 PARCIAL\";\n}\nelse {\n    msg.payload = \"🔴 CHEIA\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
